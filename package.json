{
  "name": "habitflow-pro",
  "private": true,
  "version": "1.0.0",
  "description": "HabitFlow PRO",
  "author": "Charan",
  "main": "electron.cjs",
  "type": "module",

  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "electron": "electron electron.cjs",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron electron.cjs\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },

  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },

  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wait-on": "^9.0.10"
  },

  "build": {
    "appId": "com.habitflow.pro",
    "productName": "HabitFlow PRO",
    "icon": "build/icon.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "build/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"

    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HabitFlow PRO"
    }
  },

  "allowScripts": {
    "electron-store@11.0.2": true,
    "@google/genai@2.11.0": true,
    "electron-winstaller@5.4.0": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true,
    "protobufjs@7.6.5": true,
    "electron-updater@6.8.9": true
  }
}